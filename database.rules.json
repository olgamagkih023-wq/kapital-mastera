{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "masters": {
      "$uid": {
        "settings": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        },
        "appointments": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}